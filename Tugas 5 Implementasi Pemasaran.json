    {
      "parameters": {
        "jsCode": "// 1. Fungsi untuk mengambil data hasil pencarian secara aman\nconst getOrganicData = (nodeName) => {\n  try {\n    // Mengambil semua item dari node pencarian tertentu\n    const results = $(nodeName).all();\n    \n    // Serper API menyimpan daftar berita di dalam properti 'organic'\n    return results[0].json.organic || [];\n  } catch (e) {\n    // Jika node error/tidak ada data, kembalikan array kosong agar workflow tidak berhenti\n    return [];\n  }\n};\n\n// 2. Ambil data dari masing-masing node pencarian (pastikan nama node-nya sama persis di n8n)\nconst nfaResults = getOrganicData('NFA');\nconst bisaResults = getOrganicData('BISA AI');\nconst vinixResults = getOrganicData('Vinix7');\n\n// 3. Buat stempel waktu saat ini menggunakan library Luxon (DateTime)\nconst currentTime = DateTime.now().toFormat('yyyy-MM-dd HH:mm');\n\n// 4. Gabungkan semuanya dan beri label 'brand' agar tidak tertukar\nreturn [\n  ...nfaResults.map(i => ({ json: { ...i, brand: 'NF Academy', processedAt: currentTime } })),\n  ...bisaResults.map(i => ({ json: { ...i, brand: 'BISA AI', processedAt: currentTime } })),\n  ...vinixResults.map(i => ({ json: { ...i, brand: 'Vinix 7', processedAt: currentTime } }))\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1776,
        464
      ],
      "id": "c4ac3bd5-19e1-4fb3-b614-03a11859d425",
      "name": "Gabungan Data"
    },
    {
      "parameters": {
        "jsCode": "// 1. Ambil semua data\nconst allItems = $input.all();\nconst total = allItems.length;\n\n// 2. Hitung jumlah mention\nconst counts = {\n  nfa: allItems.filter(i => i.json.brand === \"NF Academy\").length,\n  bisa: allItems.filter(i => i.json.brand === \"BISA AI\").length,\n  vinix: allItems.filter(i => i.json.brand === \"Vinix 7\").length\n};\n\n// 3. Hitung Share of Voice (SoV)\nconst sov = {\n  nfa: total > 0 ? ((counts.nfa / total) * 100).toFixed(1) : 0,\n  bisa: total > 0 ? ((counts.bisa / total) * 100).toFixed(1) : 0,\n  vinix: total > 0 ? ((counts.vinix / total) * 100).toFixed(1) : 0\n};\n\n// 4. BUAT TANGGAL DISINI (Biar tidak undefined)\nconst tanggalSekarang = DateTime.now().setZone('Asia/Jakarta').toFormat('yyyy-MM-dd HH:mm');\n\n// 5. Gabungkan teks berita\nconst combinedText = allItems.map(i => `[${i.json.brand}] ${i.json.title}`).join('\\n');\n\n// 6. LAPORKAN HASILNYA (Pastikan processedAt ada di sini)\nreturn {\n  processedAt: tanggalSekarang, // INI YANG BIKIN JADI IJO NANTI\n  metrics: {\n    total_mentions: total,\n    breakdown: counts,\n    share_of_voice: sov\n  },\n  combinedText: combinedText\n};"
      },
